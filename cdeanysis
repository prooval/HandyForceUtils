# Initialize the associative array for graph
declare -A dependencyGraph

# Path to Apex classes
apexClassDir="/git-project/csp-app/classes"

# Populate the graph
for classFile in "$apexClassDir"/*.cls; do
  className=$(basename -- "$classFile")
  className="${className%.*}"

  # Extract dependencies using refined grep pattern
  dependencies=$(grep -oE 'new [A-Za-z0-9_]+\(.*\)' "$classFile" | awk '{print $2}' | awk -F'(' '{print $1}')

  for dep in $dependencies; do
    dependencyGraph["$className"]+="$dep,"
  done
done

# Function to perform reverse traversal
getCoverageClasses() {
  local targetClass=$1
  local coverageClasses=""

  for key in "${!dependencyGraph[@]}"; do
    if [[ ${dependencyGraph[$key]} == *"$targetClass"* ]]; then
      coverageClasses+="$key,"
    fi
  done

  echo "$coverageClasses"
}
