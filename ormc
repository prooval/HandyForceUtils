// Function to save the database to disk
function saveDatabase() {
  const data = db.export();
  const buffer = Buffer.from(data);
  fs.writeFileSync("path/to/database.sqlite", buffer);
}

// Use this function when your application is about to stop
process.on('exit', saveDatabase);
process.on('SIGINT', saveDatabase);
process.on('SIGTERM', saveDatabase);
process.on('SIGUSR1', saveDatabase);
process.on('SIGUSR2', saveDatabase);
process.on('uncaughtException', saveDatabase);
