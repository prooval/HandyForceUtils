with SelectedAccounts AS (
    select * from ent_dev.as360.account where recordtypeid = '012H0000001DdcEIAS' LIMIT 50000
)

select 
    -- existing columns
    fa.as360_auditdebitenabled__c, fa.as360_autodebitaccount__c, fa.as360_autodebitrouting__c, fa.as360_balloonpayment__c, 
    -- [rest of the existing columns...]
    fa.productcode,
    -- Add primary owner logic
    CASE 
        WHEN fa.productcode IN ('DDA', 'TDA') THEN
            CASE 
                WHEN EXISTS (SELECT 1 FROM ent_dev.as360.finserv__financialaccountrole__c r 
                           WHERE r.finserv__financialaccount__c = fa.finserv__sourcesystemid__c 
                           AND r.finserv__roletype__c = 'SOL') THEN 'SOL'
                WHEN EXISTS (SELECT 1 FROM ent_dev.as360.finserv__financialaccountrole__c r 
                           WHERE r.finserv__financialaccount__c = fa.finserv__sourcesystemid__c 
                           AND r.finserv__roletype__c = 'PRI') THEN 'PRI'
                WHEN EXISTS (SELECT 1 FROM ent_dev.as360.finserv__financialaccountrole__c r 
                           WHERE r.finserv__financialaccount__c = fa.finserv__sourcesystemid__c 
                           AND r.finserv__roletype__c = 'CUS') THEN 'CUS'
                WHEN EXISTS (SELECT 1 FROM ent_dev.as360.finserv__financialaccountrole__c r 
                           WHERE r.finserv__financialaccount__c = fa.finserv__sourcesystemid__c 
                           AND r.finserv__roletype__c = 'BUS') THEN 'BUS'
                ELSE 'UNKNOWN'
            END
        WHEN fa.productcode = 'CHD' THEN
            CASE 
                WHEN EXISTS (SELECT 1 FROM ent_dev.as360.finserv__financialaccountrole__c r 
                           WHERE r.finserv__financialaccount__c = fa.finserv__sourcesystemid__c 
                           AND r.finserv__roletype__c = 'PRI') THEN 'PRI'
                WHEN EXISTS (SELECT 1 FROM ent_dev.as360.finserv__financialaccountrole__c r 
                           WHERE r.finserv__financialaccount__c = fa.finserv__sourcesystemid__c 
                           AND r.finserv__roletype__c = 'SOL') THEN 'SOL'
                WHEN EXISTS (SELECT 1 FROM ent_dev.as360.finserv__financialaccountrole__c r 
                           WHERE r.finserv__financialaccount__c = fa.finserv__sourcesystemid__c 
                           AND r.finserv__roletype__c = 'COM') THEN 'COM'
                ELSE 'UNKNOWN'
            END
        WHEN fa.productcode = 'CON' THEN
            CASE 
                WHEN EXISTS (SELECT 1 FROM ent_dev.as360.finserv__financialaccountrole__c r 
                           WHERE r.finserv__financialaccount__c = fa.finserv__sourcesystemid__c 
                           AND r.finserv__roletype__c = 'PRI') THEN 'PRI'
                WHEN EXISTS (SELECT 1 FROM ent_dev.as360.finserv__financialaccountrole__c r 
                           WHERE r.finserv__financialaccount__c = fa.finserv__sourcesystemid__c 
                           AND r.finserv__roletype__c = 'MAK') THEN 'MAK'
                WHEN EXISTS (SELECT 1 FROM ent_dev.as360.finserv__financialaccountrole__c r 
                           WHERE r.finserv__financialaccount__c = fa.finserv__sourcesystemid__c 
                           AND r.finserv__roletype__c = 'COM') THEN 'COM'
                WHEN EXISTS (SELECT 1 FROM ent_dev.as360.finserv__financialaccountrole__c r 
                           WHERE r.finserv__financialaccount__c = fa.finserv__sourcesystemid__c 
                           AND r.finserv__roletype__c = 'COB') THEN 'COB'
                ELSE 'UNKNOWN'
            END
        WHEN fa.productcode IN ('FAC', 'DRW') THEN
            CASE 
                WHEN EXISTS (SELECT 1 FROM ent_dev.as360.finserv__financialaccountrole__c r 
                           WHERE r.finserv__financialaccount__c = fa.finserv__sourcesystemid__c 
                           AND r.finserv__roletype__c = 'PRI') THEN 'PRI'
                WHEN EXISTS (SELECT 1 FROM ent_dev.as360.finserv__financialaccountrole__c r 
                           WHERE r.finserv__financialaccount__c = fa.finserv__sourcesystemid__c 
                           AND r.finserv__roletype__c = 'GEN') THEN 'GEN'
                WHEN EXISTS (SELECT 1 FROM ent_dev.as360.finserv__financialaccountrole__c r 
                           WHERE r.finserv__financialaccount__c = fa.finserv__sourcesystemid__c 
                           AND r.finserv__roletype__c = 'COM') THEN 'COM'
                WHEN EXISTS (SELECT 1 FROM ent_dev.as360.finserv__financialaccountrole__c r 
                           WHERE r.finserv__financialaccount__c = fa.finserv__sourcesystemid__c 
                           AND r.finserv__roletype__c = 'COB') THEN 'COB'
                ELSE 'UNKNOWN'
            END
        ELSE 'UNKNOWN'
    END as as360_primary_owner
from SelectedAccounts sa
join ent_dev.as360.finserv__financialaccountrole__c far on sa.finserv__customerid__c = far.finserv__relatedaccount__c
join ent_dev.as360.finserv__financialaccount__c fa on far.finserv__financialaccount__c = fa.finserv__sourcesystemid__c