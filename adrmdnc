-- /path/to/your_sql_script.sql

CREATE OR ALTER PROCEDURE AddRemoveDoNotCall
    @PhoneNumbersCSV VARCHAR(MAX),
    @EmployeeId VARCHAR(5),
    @Action VARCHAR(10)
AS
BEGIN
    -- Cleanup
    SET @EmployeeId = RTRIM(LTRIM(@EmployeeId));
  
    DECLARE @CleanedPhoneNumbers TABLE (value VARCHAR(18));
    INSERT INTO @CleanedPhoneNumbers (value)
    SELECT RTRIM(LTRIM(value)) FROM STRING_SPLIT(@PhoneNumbersCSV, ',')
    WHERE value NOT LIKE '%[^0-9]%';
    
    -- Add action
    IF @Action = 'add'
    BEGIN
        INSERT INTO donotcall (PhoneNumber, DateAdded, EmployeeId)
        SELECT value, GETDATE(), @EmployeeId
        FROM @CleanedPhoneNumbers
        WHERE NOT EXISTS (SELECT 1 FROM donotcall WHERE PhoneNumber = value);
    END

    -- Remove action
    IF @Action = 'remove'
    BEGIN
        DELETE FROM donotcall
        WHERE PhoneNumber IN (SELECT value FROM @CleanedPhoneNumbers);
    END
END

