# ~/pull_request_status_check_with_loop.sh

# Fetch Pull Request details from Bitbucket API
# Assumes BITBUCKET_API_TOKEN and PULL_REQUEST_ID are environment variables
pull_request_details=$(curl -s -u "${BITBUCKET_API_TOKEN}":x-oauth-basic "https://api.bitbucket.org/2.0/repositories/<username>/<repo_slug>/pullrequests/${PULL_REQUEST_ID}")

# Check if curl request was successful
if [ $? -ne 0 ]; then
  echo "Failed to fetch Pull Request details."
  exit 1
fi

# Initialize a variable to keep track of approval status
is_approved="false"

# Loop through the participants array and find a member with approved status
for row in $(echo "${pull_request_details}" | jq -r '.participants[] | @base64'); do
  _jq() {
    echo ${row} | base64 --decode | jq -r ${1}
  }

  if [ $(_jq '.approved') == "true" ]; then
    is_approved="true"
    break  # Exit loop as we found an approved status
  fi
done

# Check for approval status and exit script if not approved
if [ "${is_approved}" == "true" ]; then
  echo "Pull Request has been approved."
else
  echo "Pull Request is not approved."
  exit 1  # Exit script with status 1 to indicate failure
fi
