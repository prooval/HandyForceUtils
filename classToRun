# /path/to/your/script.sh

# Global variable to track if test classes need to be run
testClassRunRequired=false

getTestClassesToRun() {
  local packageXMLPath="/extract/SIT/1232/package/package.xml"
  local gitRepoPath="/git-project/csp-app/classes"
  local suppliedTestClasses=""
  local relatedTestClasses=""
  
  # Extract names of just the Apex classes from package.xml
  if grep -q '<name>ApexClass</name>' "$packageXMLPath"; then
    testClassRunRequired=true
    suppliedTestClasses=$(xmlstarlet sel -t -m "//types[name='ApexClass']/members" -v . -o ',' "$packageXMLPath" | sed 's/,$//')
  fi

  # Only proceed if testClassRunRequired is true
  if [ "$testClassRunRequired" = true ]; then
    # Identify related test classes in the Git repository that cover the Apex classes in package.xml
    apexClassesArray=($(echo "$suppliedTestClasses" | tr ',' ' '))
    for class in "${apexClassesArray[@]}"; do
      for testClass in $gitRepoPath/*Test.cls; do
        # Look for patterns or specific lines of code that indicate this test class is related to the Apex class
        if grep -q "$class" "$testClass"; then
          className=$(basename -- "$testClass")
          className="${className%.*}"
          relatedTestClasses+="$className,"
        fi
      done
    done
    relatedTestClasses=$(echo "$relatedTestClasses" | sed 's/,$//')

    # Combine test classes from package.xml and the Git repository
    if [ -n "$relatedTestClasses" ]; then
      if [ -n "$suppliedTestClasses" ]; then
        suppliedTestClasses+=","
      fi
      suppliedTestClasses+="$relatedTestClasses"
    fi

    # Use RunSpecifiedTest parameter in sfdx force:source:deploy
    echo "sfdx force:source:deploy -l RunLocalTests -r $suppliedTestClasses"
  else
    # No need to run test classes
    echo "sfdx force:source:deploy -l RunLocalTests"
  fi
}

# Call the function
getTestClassesToRun

# Using testClassRunRequired outside the function
if [ "$testClassRunRequired" = false ]; then
  echo "No need to compile related test classes."
fi
